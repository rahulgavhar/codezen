# Server
PORT=3000
NODE_ENV=development

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:5173

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Supabase project
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Clerk auth
CLERK_PUBLISHABLE_KEY=<clerk-publishable-key>
CLERK_SECRET_KEY=<clerk-secret-key>

# Judge server
JUDGE_SERVER_URL=http://<judge-host>:8080
JUDGE_AUTH_TOKEN=<judge-x-auth-token>

# Public backend base URL used to build Judge callback URL
# Example: https://codezen-oc74.onrender.com
PUBLIC_BACKEND_URL=http://localhost:3000

# Optional explicit callback URL override (if set, use this directly)
# Example: https://codezen-oc74.onrender.com/api/webhooks/judge0
JUDGE_CALLBACK_URL=

# Azure VM control (if used by your VM sync/start logic)
SUBSCRIPTION_ID=<azure-subscription-id>
TENANT_ID=<azure-tenant-id>
CLIENT_ID=<azure-client-id>
CLIENT_SECRET=<azure-client-secret>
RESOURCE_GROUP=<azure-resource-group>
VM_NAME=<azure-vm-name>
GROQ_API_KEY=<groq-api-key>